import React from 'react';
import { shallow } from 'enzyme';

import ErrorNavLink from '../ErrorNavLink';

describe('ErrorNavLink', () => {
  it('ErrorNavLink should render child', () => {
    const buttonText = 'some text';
    const wrapper = shallow(<ErrorNavLink to="/" title="title"> {buttonText} </ErrorNavLink>);
    expect(wrapper.contains(buttonText)).toBeTruthy();
  });
});

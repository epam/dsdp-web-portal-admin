import React from 'react';
import { shallow } from 'enzyme';
import useVersion from 'hooks/useVersion';
import StandardLayoutCommon from '#web-components/components/Layouts/Standard';

import ErrorLayout from '../ErrorLayout';

vi.mock('react-redux', () => {
  const redux = vi.requireActual('react-redux');
  return {
    ...redux,
    useSelector: vi.fn(),
    useDispatch: vi.fn(),
  };
});
vi.mock('react-router', () => {
  const router = vi.requireActual('react-router');
  return {
    ...router,
    useLocation: vi.fn(),
  };
});

vi.mock('hooks/useVersion', () => vi.fn());

const useVersionMock = vi.mocked(useVersion);

describe('ErrorLayout', () => {
  beforeEach(() => {
    useVersionMock.mockReturnValue({ versionId: ':versionId' });
  });
  it('should render StandardLayoutCommon ', () => {
    const wrapper = shallow(<ErrorLayout error={{}} />);
    expect(wrapper.find(StandardLayoutCommon).exists()).toBeTruthy();
  });
});

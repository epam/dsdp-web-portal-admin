import { shallow } from 'enzyme';
import React from 'react';
import IconButton from '#web-components/components/IconButton';
import PopperButton from '#web-components/components/PopperButton';

import FormTableActions from '../FormTableActions';

describe('FormTableActions', () => {
  const props = {
    onExportClick: () => vi.fn(),
    onCloneClick: () => vi.fn(),
    onDeleteClick: () => vi.fn(),
    onEditClick: () => vi.fn(),
  };
  it('should render component FormTableActions', () => {
    const wrapper = shallow(<FormTableActions {...props} />);
    expect(wrapper.find(IconButton).exists()).toBeTruthy();
    expect(wrapper.find(IconButton).length).toBe(3);
    expect(wrapper.find(PopperButton)).toBeTruthy();
  });
});

import React from 'react';
import { shallow } from 'enzyme';
import { useForm } from 'react-hook-form';
import { useLocation, useParams, useRouteMatch } from 'react-router';
import { useDispatch, useSelector } from 'react-redux';
import { MenuItem } from '@material-ui/core';
import { CALL_HISTORY_METHOD } from 'connected-react-router';

import useQuery from 'hooks/useQuery';
import { ROUTES } from 'constants/routes';
import useVersion from 'hooks/useVersion';
import useEntityMode from 'hooks/useEntityMode';
import { deleteProcessRequest, selectProcess } from 'store/process';
import { getProcessObj } from 'utils/process';

import ProcessFields from 'components/ProcessManagement/ProcessFields';
import ProcessLayout from 'components/Layouts/ProcessLayout';
import ProcessModeler from 'components/ProcessManagement/ProcessModeler';
import EditProcessPage from '../EditProcessPage';

vi.mock('react-redux', () => {
  const redux = vi.requireActual('react-redux');
  return {
    ...redux,
    useSelector: vi.fn(),
    useDispatch: vi.fn(),
  };
});

vi.mock('react-router', () => {
  return {
    useParams: vi.fn(),
    useHistory: () => ({
      push: vi.fn(),
    }),
    useRouteMatch: vi.fn(),
    useLocation: vi.fn(),
  };
});

vi.mock('react-hook-form', () => {
  const hookForm = vi.requireActual('react-hook-form');
  return {
    ...hookForm,
    useForm: vi.fn(),
    useWatch: vi.fn(),
  };
});

vi.mock('store/process', () => {
  const store = vi.requireActual('store/process');
  return {
    ...store,
    selectProcess: vi.fn(),
    selectProcessHasConflicts: vi.fn(),
    selectEditProcessIsLoading: vi.fn(),
    selectDeleteProcessIsLoading: vi.fn(),
  };
});
vi.mock('store/config', () => {
  const store = vi.requireActual('store/config');
  return {
    ...store,
    selectBpModelerTemplatesIsLoading: vi.fn(),
  };
});

vi.mock('utils/process', () => {
  const utils = vi.requireActual('utils/process');
  return {
    ...utils,
    getProcessObj: vi.fn(),
  };
});

vi.mock('hooks/useVersion', () => vi.fn());

vi.mock('hooks/useQuery', () => vi.fn());
vi.mock('hooks/useEntityMode', () => vi.fn());

const useFormMock = vi.mocked(useForm);
const useParamsMock = vi.mocked(useParams);
const useLocationMock = vi.mocked(useLocation);
const useRouteMatchMock = vi.mocked(useRouteMatch);
const useQueryMock = vi.mocked(useQuery);
const useDispatchMock = vi.mocked(useDispatch);
const useVersionMock = vi.mocked(useVersion);
const useEntityModeMock = vi.mocked(useEntityMode);
const useSelectorMock = vi.mocked(useSelector);
const selectProcessMock = selectProcess as unknown as vi.Mock;
const getProcessObjMock = vi.mocked(getProcessObj);
const handleSubmitMock = vi.fn();

describe('EditProcessPage', () => {
  const dispatch = vi.fn();
  const testVersionId = 'versionId';
  const testProcessName = 'testProcessName';
  const getValuesMock = vi.fn();

  beforeEach(() => {
    useSelectorMock.mockImplementation((fn) => fn());
    useFormMock.mockReturnValue({
      handleSubmit: handleSubmitMock,
      getValues: getValuesMock,
      control: vi.fn(),
      register: vi.fn(),
      watch: vi.fn(),
      formState: {
        isValid: true,
      },
    });
    useVersionMock.mockReturnValue({ versionId: testVersionId });
    useParamsMock.mockReturnValue({ processName: testProcessName });
    useLocationMock.mockReturnValue({ pathname: '' });
    useQueryMock.mockReturnValue({
      has: () => false,
      get: () => null,
    });
    getProcessObjMock.mockImplementation((params) => new Promise((resolve) => { resolve(params); }));
    useDispatchMock.mockReturnValue(dispatch);
    useRouteMatchMock.mockReturnValue({
      isExact: true,
      path: ROUTES.EDIT_PROCESS,
    });
    useEntityModeMock.mockReturnValue('common');
  });

  it('should include ProcessFields by default', () => {
    const wrapper = shallow(<EditProcessPage />);
    expect(wrapper.find(ProcessFields).exists()).toBeTruthy();
  });

  it('should move to a new BP on clone', async () => {
    selectProcessMock.mockImplementation(() => ({ id: 'id', name: 'name' }));
    const wrapper = shallow(<EditProcessPage />);
    const processLayout = wrapper.find(ProcessLayout);
    const Menu = () => processLayout.prop('menu') as any;

    const menuWrapper = shallow(<Menu />);
    const cloneItem = menuWrapper
      .findWhere((n) => n.text() === 'actions.clone')
      .find(MenuItem);
    const onClick = cloneItem.prop('onClick');

    if (onClick) {
      await onClick({} as any);
    }

    const params = {
      name: 'id',
      title: 'name',
      formProcessString: {
        id: 'id',
        name: 'name',
      },
    };
    expect(dispatch).toHaveBeenCalledWith({
      type: CALL_HISTORY_METHOD,
      payload: {
        args: [ROUTES.CREATE_PROCESS.replace(':versionId', testVersionId), params],
        method: 'push',
      },
    });
  });
  it('should dispatch deleteProcessRequest on delete click', async () => {
    selectProcessMock.mockImplementation(() => ({ id: 'id', name: 'name' }));
    const wrapper = shallow(<EditProcessPage />);
    const processLayout = wrapper.find(ProcessLayout);
    const Menu = () => processLayout.prop('menu') as any;

    const menuWrapper = shallow(<Menu />);
    const deleteItem = menuWrapper
      .findWhere((n) => n.text() === 'actions.delete')
      .find(MenuItem);
    const onClick = deleteItem.prop('onClick');

    if (onClick) {
      await onClick({} as any);
    }

    expect(dispatch).toHaveBeenCalledWith(deleteProcessRequest({ name: 'id', title: 'name', versionId: 'versionId' }));
  });

  it('should render ProcessModeler', () => {
    useEntityModeMock.mockReturnValue('modeler');
    selectProcessMock.mockImplementation(() => ({ id: 'id', name: 'name', formProcessString: 'formProcessString' }));
    const wrapper = shallow(<EditProcessPage />);
    expect(wrapper.find(ProcessModeler).exists()).toBeTruthy();
  });
  it('should dispatch updateProcessRequest on onSubmit action', () => {
    const submittingData = {
      formProcessString: 'formProcessString',
      title: 'title',
      name: 'name',
    };
    getValuesMock.mockReturnValue(testProcessName);
    useDispatchMock.mockReturnValue(dispatch);
    handleSubmitMock.mockImplementation((onSubmit) => onSubmit(submittingData));
    shallow(<EditProcessPage />);
    expect(dispatch).toBeCalledWith({
      type: 'process/updateProcessRequest',
      payload: {
        data: 'formProcessString', name: 'name', title: 'title', versionId: 'versionId',
      },
    });
  });
  it('should call onInvalid on onSubmit action', () => {
    useFormMock.mockReturnValue({
      handleSubmit: handleSubmitMock,
      getValues: getValuesMock,
      watch: vi.fn(),
      register: vi.fn(),
      formState: {
        isValid: false,
        isDirty: true,
      },
    });
    const submittingData = {
      formProcessString: 'formProcessString',
      title: 'title',
      name: 'name',
    };
    useDispatchMock.mockReturnValue(dispatch);
    getValuesMock.mockReturnValue(testProcessName);
    handleSubmitMock.mockImplementation((onSubmit) => onSubmit(submittingData));
    shallow(<EditProcessPage />);
    expect(dispatch).toBeCalledWith({
      type: 'process/updateProcessError',
      payload: {
        message: 'errors~form.invalidForm',
        type: 'NOTIFICATION',
      },
    });
  });
  it('should call onInvalid with correct error message when name is changed on onSubmit action', () => {
    useFormMock.mockReturnValue({
      handleSubmit: handleSubmitMock,
      getValues: getValuesMock,
      watch: vi.fn(),
      register: vi.fn(),
      formState: {
        isValid: false,
      },
    });
    const submittingData = {
      formProcessString: 'formProcessString',
      title: 'title',
      name: 'name',
    };
    useDispatchMock.mockReturnValue(dispatch);
    getValuesMock.mockReturnValue('changed name');
    handleSubmitMock.mockImplementation((onSubmit) => onSubmit(submittingData));
    shallow(<EditProcessPage />);
    expect(dispatch).toBeCalledWith({
      type: 'process/updateProcessError',
      payload: {
        message: 'text.nameChangedError',
        type: 'NOTIFICATION',
      },
    });
  });
  it('should dispatch updateProcessError on onInvalid action', () => {
    useDispatchMock.mockReturnValue(dispatch);
    getValuesMock.mockImplementation(() => testProcessName);
    handleSubmitMock.mockImplementation((_onSubmit, onInvalid) => onInvalid());
    shallow(<EditProcessPage />);
    expect(dispatch).toBeCalledWith({
      type: 'process/updateProcessError',
      payload: {
        message: 'errors~form.invalidForm',
        type: 'NOTIFICATION',
      },
    });
  });
});

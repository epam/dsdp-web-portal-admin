import React from 'react';
import { shallow } from 'enzyme';
import { useForm } from 'react-hook-form';
import { useLocation } from 'react-router';
import useVersion from 'hooks/useVersion';

import useEntityMode from 'hooks/useEntityMode';
import ProcessFields from 'components/ProcessManagement/ProcessFields';
import ProcessLayout from 'components/Layouts/ProcessLayout';
import { useDispatch } from 'react-redux';
import { push } from 'connected-react-router';
import CreateProcessPage from '../CreateProcessPage';

vi.mock('react-redux', () => {
  const redux = vi.requireActual('react-redux');
  return {
    ...redux,
    useSelector: vi.fn(),
    useDispatch: vi.fn(),
  };
});

vi.mock('hooks/useVersion', () => vi.fn());
vi.mock('hooks/useEntityMode', () => vi.fn());

const useVersionMock = vi.mocked(useVersion);

vi.mock('react-router', () => {
  return {
    useLocation: vi.fn(),
  };
});

vi.mock('react-hook-form', () => {
  const hookForm = vi.requireActual('react-hook-form');
  return {
    ...hookForm,
    useForm: vi.fn(),
  };
});

const useFormMock = vi.mocked(useForm);
const useLocationMock = vi.mocked(useLocation);
const useEntityModeMock = vi.mocked(useEntityMode);
const useDispatchMock = vi.mocked(useDispatch);
const handleSubmitMock = vi.fn();
const getValuesMock = vi.fn();

describe('CreateProcessPage', () => {
  beforeEach(() => {
    useFormMock.mockReturnValue({
      handleSubmit: handleSubmitMock,
      getValues: getValuesMock,
      watch: vi.fn(),
      register: vi.fn(),
      formState: {
        isValid: true,
        dirtyFields: {
          formProcessString: undefined,
        },
      },
    });
    useVersionMock.mockReturnValue({ versionId: ':versionId' });
    useLocationMock.mockReturnValue({ state: {} });
    useEntityModeMock.mockReturnValue('common');
  });

  it('should include ProcessFields by default', () => {
    const wrapper = shallow(<CreateProcessPage />);
    expect(wrapper.find(ProcessFields).exists()).toBeTruthy();
  });
  it('should dispatch push with correct url when onCancel click', () => {
    const dispatch = vi.fn();
    useDispatchMock.mockReturnValue(dispatch);
    const wrapper = shallow(<CreateProcessPage />);
    wrapper.find(ProcessLayout).prop('onCancel')();
    expect(dispatch).toBeCalledWith(push('/:versionId/process-list'));
  });
  it('should dispatch createProcessRequest on onSubmit action', () => {
    const submittingData = {
      formProcessString: 'formProcessString',
      title: 'title',
      name: 'name',
    };
    const dispatch = vi.fn();
    useDispatchMock.mockReturnValue(dispatch);
    getValuesMock.mockImplementation((value) => (value === 'isXmlValid' ? true : ''));
    handleSubmitMock.mockImplementation((onSubmit) => onSubmit(submittingData));
    shallow(<CreateProcessPage />);
    expect(dispatch).toBeCalledWith({
      type: 'process/createProcessRequest',
      payload: {
        data: 'formProcessString', name: 'name', title: 'title', versionId: ':versionId',
      },
    });
  });
  it('should call onInvalid on onSubmit action', () => {
    useFormMock.mockReturnValue({
      handleSubmit: handleSubmitMock,
      getValues: vi.fn(),
      watch: vi.fn(),
      register: vi.fn(),
      formState: {
        isValid: false,
        dirtyFields: {
          formProcessString: undefined,
        },
      },
    });
    const submittingData = {
      formProcessString: 'formProcessString',
      title: 'title',
      name: 'name',
    };
    const dispatch = vi.fn();
    useDispatchMock.mockReturnValue(dispatch);
    handleSubmitMock.mockImplementation((onSubmit) => onSubmit(submittingData));
    shallow(<CreateProcessPage />);
    expect(dispatch).toBeCalledWith({
      type: 'process/createProcessError',
      payload: {
        message: 'errors~form.invalidForm',
        type: 'NOTIFICATION',
      },
    });
  });

  it('should dispatch createProcessError on onInvalid action', () => {
    const dispatch = vi.fn();
    useDispatchMock.mockReturnValue(dispatch);
    handleSubmitMock.mockImplementation((_onSubmit, onInvalid) => onInvalid());
    shallow(<CreateProcessPage />);
    expect(dispatch).toBeCalledWith({
      type: 'process/createProcessError',
      payload: {
        message: 'errors~form.invalidForm',
        type: 'NOTIFICATION',
      },
    });
  });
});

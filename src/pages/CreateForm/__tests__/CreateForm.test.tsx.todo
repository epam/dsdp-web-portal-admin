import React from 'react';
import { shallow } from 'enzyme';
import { useForm } from 'react-hook-form';
import { useLocation } from 'react-router';
import useVersion from 'hooks/useVersion';

import useEntityMode from 'hooks/useEntityMode';
import FormFields from 'components/FormManagement/FormFields';
import FormLayout from 'components/Layouts/FormLayout';
import { push } from 'connected-react-router';
import { useDispatch } from 'react-redux';
import { FormType } from '#web-components/components/Form/types';
import CreateFormPage from '../CreateFormPage';

vi.mock('react-redux', () => {
  const redux = vi.requireActual('react-redux');
  return {
    ...redux,
    useSelector: vi.fn(),
    useDispatch: vi.fn(),
  };
});

vi.mock('hooks/useVersion', () => vi.fn());
vi.mock('hooks/useEntityMode', () => vi.fn());

const useVersionMock = vi.mocked(useVersion);

vi.mock('react-router', () => {
  return {
    useLocation: vi.fn(),
  };
});

vi.mock('react-hook-form', () => {
  const hookForm = vi.requireActual('react-hook-form');
  return {
    ...hookForm,
    useForm: vi.fn(),
  };
});

const useFormMock = vi.mocked(useForm);
const useLocationMock = vi.mocked(useLocation);
const useEntityModeMock = vi.mocked(useEntityMode);
const useDispatchMock = vi.mocked(useDispatch);
const handleSubmitMock = vi.fn();
const dispatch = vi.fn();

describe('CreateFormPage', () => {
  beforeEach(() => {
    useFormMock.mockReturnValue({
      handleSubmit: handleSubmitMock,
      getValues: vi.fn(),
      watch: vi.fn(),
      register: vi.fn(),
      formState: {
        isValid: true,
      },
    });
    useVersionMock.mockReturnValue({ versionId: ':versionId' });
    useLocationMock.mockReturnValue({ state: {} });
    useEntityModeMock.mockReturnValue('common');
  });

  it('should include form builder by default', () => {
    const wrapper = shallow(<CreateFormPage />);
    expect(wrapper.find(FormFields).exists()).toBeTruthy();
  });
  it('should dispatch push with correct url when onCancel click', () => {
    useDispatchMock.mockReturnValue(dispatch);
    const wrapper = shallow(<CreateFormPage />);
    wrapper.find(FormLayout).prop('onCancel')();
    expect(dispatch).toBeCalledWith(push('/:versionId/form-list'));
  });

  describe('form values', () => {
    it('should pre-populate values from location state', () => {
      const form = {
        components: [{ test: 'test' }],
        title: 'title',
        path: 'path',
      };
      useLocationMock.mockReturnValue({ state: form });

      shallow(<CreateFormPage />);

      expect(useFormMock).toHaveBeenCalledWith(expect.objectContaining({
        defaultValues: {
          formSchema: {
            display: 'form',
            components: [{ test: 'test' }],
          },
          title: 'Copy_title',
          path: '',
          type: { value: FormType.form, label: FormType.form },
          roles: [],
          showOnCardList: false,
        },
      }));
    });
  });
  it('should dispatch form/createFormRequest on onSubmit action', () => {
    const submittingData = {
      jsonSchemeIsInValid: false,
      title: 'title',
      path: 'path',
      formSchema: {},
      type: { value: FormType.form, label: FormType.form },
      roles: [],
      showOnCardList: false,
    };
    useDispatchMock.mockReturnValue(dispatch);
    handleSubmitMock.mockImplementation((onSubmit) => onSubmit(submittingData));
    shallow(<CreateFormPage />);
    expect(dispatch).toBeCalledWith({
      type: 'form/createFormRequest',
      payload: {
        data: {
          path: 'path',
          name: 'path',
          title: 'title',
          type: FormType.form,
          roles: [],
          showOnCardList: false,
        },
        versionId: ':versionId',
      },
    });
  });
  it('should dispatch form/createFormError on onSubmit action if jsonSchemeIsInValid', () => {
    const submittingData = {
      jsonSchemeIsInValid: true,
      title: 'title',
      path: 'path',
      formSchema: {},
      type: { value: FormType.form, label: FormType.form },
      roles: [],
      showOnCardList: false,
    };
    useDispatchMock.mockReturnValue(dispatch);
    handleSubmitMock.mockImplementation((onSubmit) => onSubmit(submittingData));
    shallow(<CreateFormPage />);
    expect(dispatch).toBeCalledWith({
      type: 'form/createFormError',
      payload: {
        message: 'text.formInvalidJson',
        type: 'NOTIFICATION',
      },
    });
  });
  it('should call onInvalid on onSubmit action', () => {
    useFormMock.mockReturnValue({
      handleSubmit: handleSubmitMock,
      getValues: vi.fn(),
      watch: vi.fn(),
      register: vi.fn(),
      formState: {
        isValid: false,
      },
    });
    const submittingData = {
      jsonSchemeIsInValid: 'jsonSchemeIsInValid',
      title: 'title',
      path: 'path',
      formSchema: {},
      type: { value: FormType.form, label: FormType.form },
      roles: [],
      showOnCardList: false,
    };
    useDispatchMock.mockReturnValue(dispatch);
    handleSubmitMock.mockImplementation((onSubmit) => onSubmit(submittingData));
    shallow(<CreateFormPage />);
    expect(dispatch).toBeCalledWith({
      type: 'form/createFormError',
      payload: {
        message: 'errors~form.invalidForm',
        type: 'NOTIFICATION',
      },
    });
  });
  it('should dispatch createFormError on onInvalid action', () => {
    useDispatchMock.mockReturnValue(dispatch);
    handleSubmitMock.mockImplementation((_onSubmit, onInvalid) => onInvalid());
    shallow(<CreateFormPage />);
    expect(dispatch).toBeCalledWith({
      type: 'form/createFormError',
      payload: {
        message: 'errors~form.invalidForm',
        type: 'NOTIFICATION',
      },
    });
  });
});

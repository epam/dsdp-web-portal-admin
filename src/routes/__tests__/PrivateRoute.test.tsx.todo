import React from 'react';
import { shallow } from 'enzyme';
import useVersion from 'hooks/useVersion';

import useAuthentication from 'hooks/useAuthentication';
import PrivateRoute from '../PrivateRoute';

const TestComponent = () => <span>testText</span>;
vi.mock('hooks/useAuthentication', () => vi.fn());
vi.mock('react-redux', () => ({
  useDispatch: vi.fn(),
}));

vi.mock('hooks/useVersion', () => vi.fn());

const useVersionMock = vi.mocked(useVersion);
const useAuthenticationMock = vi.mocked(useAuthentication);

describe('PrivateRoute', () => {
  beforeEach(() => {
    useVersionMock.mockReturnValue({ versionId: ':versionId' });
  });
  it('Component should be rendered if user is authenticated', () => {
    useAuthenticationMock.mockReturnValue({ authenticated: true });
    const route = shallow(<PrivateRoute component={TestComponent} roles={['*']} />);
    const Component = route.prop('render');
    const renderValue = shallow(<Component />);
    expect(renderValue.find(TestComponent)).toHaveLength(1);
  });

  it('Redirect should be rendered if user is not authenticated', () => {
    useAuthenticationMock.mockReturnValue({ authenticated: false });
    const route = shallow(<PrivateRoute component={TestComponent} roles={['*']} />);
    const Component = route.prop('render');
    const renderValue = shallow(<Component />);
    expect(renderValue.props()).toMatchObject({ to: { pathname: '/login' } });
  });

  it('Component should be rendered if user has correct realm role', () => {
    const realmRole = 'realmRole1';
    useAuthenticationMock.mockReturnValue({
      authenticated: true,
      hasRealmRole: (r: string) => r === realmRole,
      hasResourceRole: (r: string) => r === 'realmRole2',
    });
    const route = shallow(<PrivateRoute component={TestComponent} roles={[realmRole]} />);
    const Component = route.prop('render');
    const renderValue = shallow(<Component />);
    expect(renderValue.find(TestComponent)).toHaveLength(1);
  });

  it('Component should be rendered if user has not correct realm role', () => {
    const realmRole = 'realmRole1';
    useAuthenticationMock.mockReturnValue({
      authenticated: true,
      hasRealmRole: (r: string) => r === realmRole,
      hasResourceRole: (r: string) => r === 'realmRole2',
    });
    const route = shallow(<PrivateRoute component={TestComponent} roles={['realmRole2']} />);
    const Component = route.prop('render');
    const renderValue = shallow(<Component />);
    expect(renderValue.props()).toMatchObject({ to: { pathname: '/:versionId/forbidden' } });
  });

  it('Redirect should be rendered if no authentication instance exists', () => {
    useAuthenticationMock.mockReturnValue(false);
    const route = shallow(<PrivateRoute component={TestComponent} roles={['*']} />);
    const Component = route.prop('render');
    const renderValue = shallow(<Component />);
    expect(renderValue.props()).toMatchObject({ to: { pathname: '/login' } });
  });
});

{
  "name": "admin-portal",
  "version": "0.1.0",
  "private": false,
  "engines": {
    "node": ">=14.5",
    "npm": ">=7"
  },
  "scripts": {
    "analyze": "source-map-explorer 'build/static/js/*.js'",
    "start": "vite",
    "build": "vite build && node scripts/prepare-theme-files.js",
    "build:clean": "vite build && node scripts/prepare-theme-files.js",
    "build:prod": "vite build && node scripts/prepare-theme-files.js",
    "test": "vitest",
    "test:coverage": "CI=true vitest run --coverage",
    "test:coverage:dev": "vitest run --coverage --coverage.reporter=text",
    "test:coverage:win": "vitest run --coverage",
    "eject": "react-scripts eject",
    "lint": "npm run type-check && eslint --ext .ts --ext .tsx src",
    "onlyLint": "eslint --ext .ts --ext .tsx src",
    "type-check": "tsc --noEmit --skipLibCheck",
    "precommit": "npm run lint && npm run test:coverage"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "dependencies": {
    "@bpmn-io/element-template-chooser": "0.1.0",
    "@bpmn-io/properties-panel": "0.22.0",
    "@material-ui/core": "4.12.4",
    "@material-ui/icons": "4.11.3",
    "@reduxjs/toolkit": "1.9.0",
    "@testing-library/jest-dom": "6.5.0",
    "@testing-library/react": "14.3.1",
    "@vitejs/plugin-react": "4.7.0",
    "@vitest/coverage-v8": "3.2.4",
    "bootstrap": "4.6.2",
    "bpmn-js": "10.0.0",
    "bpmn-js-properties-panel": "1.8.1",
    "bpmn-moddle": "7.1.3",
    "camunda-bpmn-moddle": "7.0.1",
    "clsx": "1.1.1",
    "formiojs": "4.21.7",
    "history": "5.3.0",
    "i18next": "20.6.1",
    "i18next-browser-languagedetector": "7.2.0",
    "iso-639-1": "3.1.2",
    "js-cookie": "3.0.1",
    "lodash": "4.17.23",
    "luxon": "1.28.1",
    "monaco-ace-tokenizer": "0.2.3",
    "monaco-editor": "0.34.1",
    "monaco-languageclient": "4.0.3",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-dropzone": "14.2.1",
    "react-helmet": "6.1.0",
    "react-hook-form": "7.36.0",
    "react-i18next": "11.18.6",
    "react-redux": "7.2.6",
    "react-router": "7.13.0",
    "reapop": "3.0.4",
    "reconnecting-websocket": "4.4.0",
    "redux": "4.1.2",
    "redux-devtools-extension": "2.13.9",
    "redux-observable": "2.0.0",
    "reselect": "4.1.5",
    "rxjs": "7.5.4",
    "tslib": "2.3.1",
    "typescript": "5.8.3",
    "uuid": "8.3.2",
    "vite": "7.3.1",
    "vite-plugin-svgr": "4.3.0",
    "vite-tsconfig-paths": "5.1.4",
    "vitest": "3.2.4",
    "vscode-ws-jsonrpc": "2.0.1",
    "web-vitals": "0.2.4"
  },
  "devDependencies": {
    "@testing-library/react-hooks": "5.0.3",
    "@testing-library/user-event": "14.6.1",
    "@types/history": "4.7.11",
    "@types/js-cookie": "3.0.1",
    "@types/lodash": "4.14.179",
    "@types/node": "14.18.12",
    "@types/react": "18.3.1",
    "@types/react-dom": "18.3.1",
    "@types/react-helmet": "6.1.7",
    "@types/react-redux": "7.1.23",
    "@types/react-router-dom": "5.3.3",
    "@types/uuid": "8.3.4",
    "@typescript-eslint/eslint-plugin": "5.62.0",
    "@typescript-eslint/parser": "5.62.0",
    "baseline-browser-mapping": "2.9.8",
    "cheerio": "1.0.0-rc.10",
    "eslint": "8.57.1",
    "eslint-config-airbnb": "19.0.4",
    "eslint-config-airbnb-typescript": "17.0.0",
    "eslint-config-react": "1.1.7",
    "eslint-plugin-import": "2.26.0",
    "eslint-plugin-jsx-a11y": "6.6.0",
    "eslint-plugin-react": "7.30.1",
    "eslint-plugin-react-hooks": "4.6.0",
    "fs-extra": "11.2.0",
    "sass": "1.89.2"
  },
  "homepage": "/admin"
}
